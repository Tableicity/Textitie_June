    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "pdfjs-dist": "4.10.38",
    "pino": "^9",
    "pino-http": "^10",
    "stripe": "^22.2.1",
    "stripe-replit-sync": "^1.0.0",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
